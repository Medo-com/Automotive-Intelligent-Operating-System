@{
    ViewData["Title"] = "AI Vehicle Pricing Tools";
}

<h2 class="page-title">AI Pricing & Trade-In Tools</h2>

<!-- ===============================================================
     SECTION 1 — SMART PRICING (VALUE ESTIMATOR)
================================================================= -->

<div class="aios-card fade-in modern-card">

    <h3 class="section-title">AI Vehicle Value Estimator</h3>

    <div class="input-grid">
        <div class="input-group">
            <label>Year</label>
            <input id="price-year" class="modern-input" placeholder="e.g. 2020" />
        </div>

        <div class="input-group">
            <label>Make</label>
            <input id="price-make" class="modern-input" placeholder="e.g. Honda" />
        </div>

        <div class="input-group">
            <label>Model</label>
            <input id="price-model" class="modern-input" placeholder="e.g. Civic" />
        </div>

        <div class="input-group">
            <label>Mileage (km)</label>
            <input id="price-mileage" class="modern-input" placeholder="e.g. 85000" />
        </div>
    </div>

    <div class="button-row">
        <button class="modern-btn" onclick="estimatePrice()">Estimate Price</button>
    </div>

    <div class="result-box">
        <h5>AI Suggested Value</h5>
        <p id="price-result" class="result-text">—</p>
    </div>

</div>

<br />
<br />


<!-- ===============================================================
     SECTION 2 — TRADE-IN ESTIMATOR
================================================================= -->

<div class="tradein-card fade-in">

    <h3 class="section-title">AI Trade-In Offer Estimator</h3>

    <div class="input-grid">

        <div class="input-group">
            <label>Year</label>
            <input id="trade-year" class="modern-input" type="number" placeholder="2017" required />
        </div>

        <div class="input-group">
            <label>Make</label>
            <input id="trade-make" class="modern-input" placeholder="Honda" required />
        </div>

        <div class="input-group">
            <label>Model</label>
            <input id="trade-model" class="modern-input" placeholder="Civic" required />
        </div>

        <div class="input-group">
            <label>Mileage (KM)</label>
            <input id="trade-mileage" class="modern-input" type="number" placeholder="120000" required />
        </div>

        <div class="input-group full">
            <label>Condition</label>
            <select id="trade-condition" class="modern-input">
                <option>Excellent</option>
                <option>Good</option>
                <option>Fair</option>
                <option>Poor</option>
            </select>
        </div>

        <div class="input-group full">
            <label>Notes (Optional)</label>
            <textarea id="trade-notes" class="modern-input textarea" rows="3"
                      placeholder="Scratches, accident history, trim level..."></textarea>
        </div>
    </div>

    <button class="modern-btn" onclick="estimateTradeIn()">Estimate Trade-In Value</button>

    <div class="output-card">
        <h4 class="output-title">AI Trade-In Estimate</h4>
        <pre id="trade-result" class="ai-output">Awaiting input...</pre>
    </div>

</div>


<!-- ===============================================================
     JAVASCRIPT FOR BOTH ESTIMATORS
================================================================= -->
<script>

    /* ---------- SMART PRICING ---------- */
    async function estimatePrice() {
        document.getElementById("price-result").innerText = "Estimating...";

        const payload = {
            year: document.getElementById("price-year").value,
            make: document.getElementById("price-make").value,
            model: document.getElementById("price-model").value,
            mileage: document.getElementById("price-mileage").value
        };

        const res = await fetch('/api/ai-pricing/estimate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });

        const data = await res.json();
        let price = data.price;

        if (price) {
            price = price.replace(/[^\d]/g, "");
            price = Number(price).toLocaleString("en-US");
            document.getElementById("price-result").innerText = "$" + price;
        } else {
            document.getElementById("price-result").innerText = "Error retrieving value";
        }
    }


    /* ---------- TRADE-IN ESTIMATOR ---------- */
    async function estimateTradeIn() {
        document.getElementById("trade-result").innerText = "Estimating...";

        const payload = {
            year: parseInt(document.getElementById("trade-year").value),
            make: document.getElementById("trade-make").value,
            model: document.getElementById("trade-model").value,
            mileage: parseInt(document.getElementById("trade-mileage").value),
            condition: document.getElementById("trade-condition").value,
            notes: document.getElementById("trade-notes").value
        };

        const res = await fetch('/api/ai/tradein/estimate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });

        const data = await res.json();
        document.getElementById("trade-result").innerText =
            data.estimate || "Error retrieving estimate.";
    }

</script>


<!-- ===============================================================
     MERGED CSS (NO DUPLICATES)
================================================================= -->
<style>

    .page-title {
        font-size: 2rem;
        font-weight: 600;
        margin: 20px;
        text-align: center;
        color: #2c3e50;
    }

    /* CARD STYLE (used by both tools) */
    .modern-card,
    .tradein-card {
        padding: 35px;
        border-radius: 20px;
        background: #ffffff;
        box-shadow: 0 6px 20px rgba(0,0,0,0.08);
        border: 1px solid #e5e7eb;
        max-width: 950px;
        margin: 0 auto;
    }

    .section-title {
        margin-bottom: 25px;
        font-size: 1.4rem;
        font-weight: 700;
        color: #2c3e50;
        text-align: left;
    }

    /* GRID */
    .input-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 28px;
        margin-bottom: 30px;
    }

    .full {
        grid-column: span 2;
    }

    /* LABELS */
    .input-group label {
        font-size: 0.95rem;
        font-weight: 600;
        margin-bottom: 8px;
        color: #374151;
        display: block;
    }

    /* INPUTS */
    .modern-input {
        width: 100%;
        padding: 14px 16px;
        border-radius: 10px;
        border: 1px solid #d1d5db;
        background: #f9fafb;
        font-size: 1rem;
        transition: .2s ease-in-out;
    }

        .modern-input:focus,
        .modern-input:hover {
            background: white;
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37,99,235,.2);
        }

    /* BUTTONS */
    .modern-btn {
        width: 100%;
        padding: 15px;
        border-radius: 12px;
        background: #2563eb;
        color: white;
        font-size: 1.1rem;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: .25s;
        margin-top: 5px;
    }

        .modern-btn:hover {
            background: #1d4ed8;
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(0,0,0,.12);
        }

    .button-row {
        display: flex;
        gap: 12px;
        margin-top: 10px;
    }

    /* PRICE RESULT */
    .result-box {
        margin-top: 30px;
        padding: 18px;
        border-radius: 12px;
        background: #f1f5ff;
        border-left: 4px solid #4c8bf5;
    }

    .result-text {
        font-size: 1.4rem;
        font-weight: 700;
        color: #1c3d8a;
    }

    /* TRADE-IN OUTPUT */
    .output-card {
        margin-top: 30px;
        padding: 20px;
        border-radius: 15px;
        background: #f8fafc;
        border: 1px solid #dbeafe;
    }

    .output-title {
        font-size: 1.2rem;
        font-weight: 700;
        margin-bottom: 10px;
        color: #1e293b;
    }

    .ai-output {
        white-space: pre-wrap;
        padding: 15px;
        font-size: 1rem;
        background: #eef2ff;
        border-radius: 10px;
        border: 1px solid #c7d2fe;
        font-family: Consolas, monospace;
    }

    /* Mobile */
    @@media (max-width: 700px) {
        .input-grid {
            grid-template-columns: 1fr;
        }
    }

</style>
