@model AIOS.Models.FinanceCalculation
@{
    ViewData["Title"] = "Finance Calculator";
}

<h2 class="page-title">Finance Calculator</h2>

<div class="aios-card fade-in">
    <form asp-action="Calculator" method="post">

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="VehiclePrice">Vehicle Price</label>
                <input asp-for="VehiclePrice" class="aios-input" type="number" step="0.01" min="0.01" />
                <span asp-validation-for="VehiclePrice" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="CreditScore">Credit Score</label>
                <input asp-for="CreditScore" class="aios-input" type="number" min="300" max="850" />
                <span asp-validation-for="CreditScore" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="LoanTerm">Loan Term</label>
                <input asp-for="LoanTerm" class="aios-input" type="number" min="1" />
                <span asp-validation-for="LoanTerm" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="TermUnit">Term Unit</label>
                <select asp-for="TermUnit" class="aios-input">
                    <option value="Months">Months</option>
                    <option value="Years">Years</option>
                </select>
                <span asp-validation-for="TermUnit" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="DownPayment">Down Payment (Optional)</label>
                <input asp-for="DownPayment" class="aios-input" type="number" step="0.01" min="0" />
                <span asp-validation-for="DownPayment" class="text-danger"></span>
            </div>

            <!-- Button moved lower -->
            <div class="col-12 mt-4">
                <button type="submit" class="btn-aios btn-calc">Calculate</button>
            </div>
        </div>
    </form>
</div>


<!-- Always visible AI Loan Approval section -->
<div class="aios-card fade-in mt-4">
    <h3 class="page-title" style="font-size: 1.3rem; margin-bottom: 15px;">AI Loan Approval</h3>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="stat-card ai-probability">
                <div class="stat-title">Approval Likelihood</div>
                <div id="ai-approval" class="stat-value ai-waiting">Waiting for information...</div>
                <p id="ai-insight" class="text-muted mt-2"></p>
            </div>
        </div>
    </div>
</div>


@if (Model != null && Model.MonthlyPayment > 0)
{
    <div class="aios-card fade-in mt-4">
        <h3 class="page-title" style="font-size: 1.3rem; margin-bottom: 15px;">Calculation Results</h3>

        <div class="row g-3">

            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-title">Interest Rate</div>
                    <div class="stat-value">@Model.InterestRate.ToString("F2")%</div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-title">Monthly Payment</div>
                    <div class="stat-value">@Model.MonthlyPayment.ToString("C")</div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-title">Total Amount Paid</div>
                    <div class="stat-value">@Model.TotalPaid.ToString("C")</div>
                </div>
            </div>

        </div>
    </div>
}

<script>
    document.addEventListener("DOMContentLoaded", () => {

        // Only run after a calculation is performed
        const el = document.getElementById("ai-approval");
        const insight = document.getElementById("ai-insight");

        // If the model doesn't contain a payment, do nothing
        if (@(Model == null || Model.MonthlyPayment <= 0 ? "true" : "false"))
            return;

        const payload = {
            creditScore: @(Model?.CreditScore ?? 0),
            vehiclePrice: @(Model?.VehiclePrice ?? 0),
            downPayment: @(Model?.DownPayment ?? 0),
            loanTerm: @(Model?.LoanTerm ?? 0),
            termUnit: "@(Model?.TermUnit ?? "")"
        };

        el.innerText = "Calculating...";

        fetch('/api/ai/loan-approval', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        })
        .then(r => r.json())
        .then(data => {

            el.classList.remove("ai-waiting");

            if (!data || !data.probability) {
                el.innerText = "N/A";
                return;
            }

            el.innerText = data.probability + "%";

            if (data.reason)
                insight.innerText = data.reason;

            if (data.probability >= 80) {
                el.style.color = "green";
            } else if (data.probability >= 50) {
                el.style.color = "#e6b800";
            } else {
                el.style.color = "red";
            }
        })
        .catch(() => {
            el.innerText = "Error";
        });
    });
</script>

<style>
    .btn-calc {
        margin-top: 10px;
        padding: 14px 26px;
        font-size: 1.1rem;
    }

    .ai-waiting {
        color: #6c757d !important;
        font-style: italic;
    }

    .stat-card {
        padding: 20px;
        border-radius: 12px;
        background: #f8f9fc;
        border: 1px solid #e3e4e7;
        text-align: center;
    }

    .stat-title {
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 5px;
        color: #555;
    }

    .stat-value {
        font-size: 1.6rem;
        font-weight: 700;
    }

    .ai-probability {
        border-left: 4px solid #4c8bf5;
    }

    .aios-card {
        padding: 30px;
        border-radius: 16px;
    }
</style>
